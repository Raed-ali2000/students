<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام إدارة الدفعات</title>
    <style>
        :root { --primary-color: #2c3e50; --accent-color: #27ae60; --bg-color: #f8f9fa; }
        body { font-family: 'Segoe UI', sans-serif; background-color: var(--bg-color); padding: 15px; direction: rtl; }
        .container { max-width: 500px; margin: auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h2 { color: var(--primary-color); text-align: center; border-bottom: 2px solid var(--accent-color); padding-bottom: 10px; }
        label { display: block; margin: 10px 0 5px; font-weight: bold; }
        input, select { width: 100%; padding: 12px; margin-bottom: 10px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background-color: var(--accent-color); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; margin-bottom: 10px; }
        .payment-card { background: #fff; border-right: 5px solid var(--accent-color); padding: 10px; margin-bottom: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border-radius: 4px; position: relative; }
        .delete-btn { position: absolute; left: 10px; top: 10px; color: red; cursor: pointer; font-weight: bold; }
        .total-box { background: var(--primary-color); color: white; padding: 15px; text-align: center; border-radius: 8px; font-size: 18px; }
    </style>
</head>
<body>

<div class="container">
    <h2>(الادخالات)</h2>
    
    <div style="background: #e9ecef; padding: 10px; border-radius: 8px; margin-bottom: 20px;">
        <label>إضافة بيت جديد:</label>
        <input type="text" id="newHouseName" placeholder="مثلاً: A4 علي">
        <button style="background-color: var(--primary-color);" onclick="addNewHouse()">إضافة البيت للقائمة</button>
    </div>

    <label>اختر الدار:</label>
    <select id="houseSelect"></select>

    <label>المبلغ:</label>
    <input type="number" id="amount" placeholder="0.00">

    <label>التاريخ:</label>
    <input type="date" id="date">

    <button onclick="savePayment()">حفظ الدفعة</button>

    <hr>
    <h2>(المخرجات)</h2>
    <div id="paymentList"></div>

    <div class="total-box">إجمالي المبالغ: <span id="totalDisplay">0</span> د.ع</div>
</div>

<script>
    document.getElementById('date').valueAsDate = new Date();

    // إدارة قائمة البيوت
    function loadHouses() {
        let houses = JSON.parse(localStorage.getItem('myApp_houses')) || ["A1 عبد", "B3 محمد"];
        const select = document.getElementById('houseSelect');
        select.innerHTML = "";
        houses.forEach(h => {
            select.innerHTML += `<option value="${h}">${h}</option>`;
        });
    }

    function addNewHouse() {
        const name = document.getElementById('newHouseName').value;
        if(name === "") return;
        let houses = JSON.parse(localStorage.getItem('myApp_houses')) || ["A1 عبد", "B3 محمد"];
        houses.push(name);
        localStorage.setItem('myApp_houses', JSON.stringify(houses));
        document.getElementById('newHouseName').value = "";
        loadHouses();
        alert("تمت إضافة البيت بنجاح");
    }

    // إدارة الدفعات
    function savePayment() {
        const house = document.getElementById('houseSelect').value;
        const amount = document.getElementById('amount').value;
        const date = document.getElementById('date').value;
        if (amount === "") return;

        const payment = { house, amount: parseFloat(amount), date, id: Date.now() };
        let payments = JSON.parse(localStorage.getItem('myApp_payments')) || [];
        payments.push(payment);
        localStorage.setItem('myApp_payments', JSON.stringify(payments));
        document.getElementById('amount').value = "";
        displayPayments();
    }

    function displayPayments() {
        const list = document.getElementById('paymentList');
        let payments = JSON.parse(localStorage.getItem('myApp_payments')) || [];
        list.innerHTML = "";
        let total = 0;

        payments.reverse().forEach(item => {
            total += item.amount;
            list.innerHTML += `
                <div class="payment-card">
                    <span class="delete-btn" onclick="deleteEntry(${item.id})">X</span>
                    <p><strong>الدار:</strong> ${item.house}</p>
                    <p><strong>المبلغ:</strong> ${item.amount.toLocaleString()} د.ع</p>
                    <p><strong>التاريخ:</strong> ${item.date}</p>
                </div>`;
        });
        document.getElementById('totalDisplay').innerText = total.toLocaleString();
    }

    function deleteEntry(id) {
        if(!confirm("حذف هذه الدفعة؟")) return;
        let payments = JSON.parse(localStorage.getItem('myApp_payments')) || [];
        payments = payments.filter(p => p.id !== id);
        localStorage.setItem('myApp_payments', JSON.stringify(payments));
        displayPayments();
    }

    loadHouses();
    displayPayments();
</script>

</body>
</html>

